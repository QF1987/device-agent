prefix=/tmp/grpc-android-install
exec_prefix=/tmp/grpc-android-install
libdir=/tmp/grpc-android-install/lib
sharedlibdir=/tmp/grpc-android-install/lib
includedir=/tmp/grpc-android-install/include

Name: zlib
Description: zlib compression library
Version: 1.3

Requires:
Libs: -L${libdir} -L${sharedlibdir} -lz
Cflags: -I${includedir}
